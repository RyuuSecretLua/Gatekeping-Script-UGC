end)

Credits:CreateButton('Copy Fier YouTube', function()
	setclipboard('https://youtube.com/@itsfier?si=QkKZ2tCWqDMK14wU')
end)
local fake = Instance.new("BindableEvent")
player.Idled:Connect(function()
	if antiAfk then
		fake:Fire()
	end
end)

while true do
	task.wait()
	if antiAfk then
		fake:Fire()
	end
