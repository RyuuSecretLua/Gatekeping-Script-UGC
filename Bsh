local logCount = 0

local function addLog(msg, color)
	logCount += 1

	local lbl = Instance.new("TextLabel")
	lbl.Parent = LogFrame
	lbl.BackgroundTransparency = 1
	lbl.Size = UDim2.new(1, -4, 0, 18)
	lbl.Font = Enum.Font.Code
	lbl.Text = "[" .. os.date("%H:%M:%S") .. "] " .. msg
	lbl.TextColor3 = color or Color3.fromRGB(200, 200, 230)
	lbl.TextSize = 11
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.TextWrapped = true
	lbl.AutomaticSize = Enum.AutomaticSize.Y
	lbl.LayoutOrder = logCount
	lbl.ZIndex = 2

	task.defer(function()
		LogFrame.CanvasSize = UDim2.new(0, 0, 0, LogLayout.AbsoluteContentSize.Y + 8)
		LogFrame.CanvasPosition = Vector2.new(0, math.huge)
	end)
end

local function getIds()
	local ids = {}
	for v in IdInput.Text:gmatch("%d+") do
		local n = tonumber(v)
		if n then
			table.insert(ids, n)
		end
	end
	return ids
end

-- UI DEMO ONLY
local function getDiamond()
	local ids = getIds()
	if #ids == 0 then
		addLog("Enter ID first.", Color3.fromRGB(255, 200, 80))
		return
	end

	addLog("IDs detected: " .. table.concat(ids, ", "), Color3.fromRGB(180, 180, 255))
	addLog("UI sample ready.", Color3.fromRGB(100, 255, 200))
end

